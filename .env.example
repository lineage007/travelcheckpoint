# TravelCheckpoint — required environment variables
# Copy to .env.local for local dev; set in Vercel dashboard for production.

# ── Core ─────────────────────────────────────────────
# Public base URL — used by the price-alert runner to call /api/search.
# Set to your Vercel deployment URL (e.g. https://travelcheckpoint.vercel.app).
# If omitted, the alert runner will fall back to the automatic VERCEL_URL env var.
NEXT_PUBLIC_BASE_URL=https://travelcheckpoint.vercel.app

# ── Security ─────────────────────────────────────────
# Pre-shared secret for POST /api/alerts — prevents unauthenticated alert creation.
# Generate with: openssl rand -hex 32
# Must be sent as header: X-TC-Secret: <value>
TC_SECRET=

# ── Telegram notifications ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DROP_THRESHOLD_PCT=10

# ── Flight data ──────────────────────────────────────
SEATS_AERO_API_KEY=
SERPAPI_KEY=
CASH_FLIGHTS_API_URL=

# ── Hotel data ───────────────────────────────────────
LITEAPI_KEY=

# ── AI (chat assistant) ──────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Booking integrations ─────────────────────────────
DUFFEL_ACCESS_TOKEN=
